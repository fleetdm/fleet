<?xml version="1.0" encoding="utf-8"?>
<!--
  CIS Windows 11 Enterprise Benchmark (Intune) v8.1 - Windows Defender Configuration Profile
  Applies Microsoft Defender Antivirus and Attack Surface Reduction settings via MDM SyncML

  Covered CIS Controls:
  - 5.3   Allow Behavior Monitoring: Enabled (1)
  - 5.4   Allow Email Scanning: Enabled (1)
  - 5.5   Allow Full Scan Removable Drive Scanning: Enabled (1)
  - 5.6   Allow Realtime Monitoring: Enabled (1)
  - 5.7   Allow IOAV Protection: Enabled (1)
  - 5.8   Allow Script Scanning: Enabled (1)
  - 5.9   Enable Network Protection: Enabled in Block Mode (1)
  - 5.10  PUA Protection: Enabled (1)
  - 5.11+ Attack Surface Reduction Rules: Block mode (1) for all CIS rules

  ASR Rule GUIDs:
  - 56A863A9-875E-4185-98A7-B882C64B5CE5: Block abuse of exploited vulnerable signed drivers
  - 7674BA52-37EB-4A4F-A9A1-F0F9A1619A2C: Block Adobe Reader from creating child processes
  - D4F940AB-401B-4EFC-AADC-AD5F3C50688A: Block all Office applications from creating child processes
  - 9E6C4E1F-7D60-472F-BA1A-A39EF669E4B2: Block credential stealing from Windows LSASS
  - BE9BA2D9-53EA-4CDC-84E5-9B1EEEE46550: Block executable content from email client and webmail
  - 01443614-CD74-433A-B99E-2ECDC07BFC25: Block executable files from running unless they meet criteria
  - 5BEB7EFE-FD9A-4556-801D-275E5FFC04CC: Block execution of potentially obfuscated scripts
  - D3E037E1-3EB8-44C8-A917-57927947596D: Block JavaScript or VBScript from launching downloaded executables
  - 3B576869-A4EC-4529-8536-B80A7769E899: Block Office applications from creating executable content
  - 75668C1F-73B5-4CF0-BB93-3ECF5CB7CC84: Block Office applications from injecting code into other processes
  - 26190899-1602-49E8-8B27-EB1D0A1CE869: Block Office communication application from creating child processes
  - E6DB77E5-3DF2-4CF1-B95A-636979351E5B: Block persistence through WMI event subscription
  - D1E49AAC-8F56-4280-B9BA-993A6D77406C: Block process creations originating from PSExec and WMI commands
  - B2B3F03D-6A65-4F7B-A9C7-1C7EF74A9BA4: Block untrusted and unsigned processes that run from USB
  - 92E97FA1-2EDF-4476-BDD6-9DD0B4DDDC7B: Block Win32 API calls from Office macros
  - C1DB55AB-C21A-4637-BB3F-A12568109D35: Use advanced protection against ransomware
-->
<SyncML xmlns="SYNCML:SYNCML1.2">
  <SyncBody>

    <!-- Allow Behavior Monitoring: Enabled -->
    <Replace>
      <CmdID>1</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AllowBehaviorMonitoring</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- Allow Email Scanning: Enabled -->
    <Replace>
      <CmdID>2</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AllowEmailScanning</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- Allow Full Scan Removable Drive Scanning: Enabled -->
    <Replace>
      <CmdID>3</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AllowFullScanRemovableDriveScanning</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- Allow Realtime Monitoring: Enabled -->
    <Replace>
      <CmdID>4</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AllowRealtimeMonitoring</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- Allow IOAV Protection: Enabled -->
    <Replace>
      <CmdID>5</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AllowIOAVProtection</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- Allow Script Scanning: Enabled -->
    <Replace>
      <CmdID>6</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AllowScriptScanning</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- Enable Network Protection: Block mode -->
    <Replace>
      <CmdID>7</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/EnableNetworkProtection</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!-- PUA Protection: Enabled -->
    <Replace>
      <CmdID>8</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/PUAProtection</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <!--
      Attack Surface Reduction Rules
      Format: <GUID>=<state>|<GUID>=<state>...  (pipe-delimited, state 1=block, 2=audit)
      All rules set to Block (1)
    -->
    <Replace>
      <CmdID>9</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/Defender/AttackSurfaceReductionRules</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">chr</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>56A863A9-875E-4185-98A7-B882C64B5CE5=1|7674BA52-37EB-4A4F-A9A1-F0F9A1619A2C=1|D4F940AB-401B-4EFC-AADC-AD5F3C50688A=1|9E6C4E1F-7D60-472F-BA1A-A39EF669E4B2=1|BE9BA2D9-53EA-4CDC-84E5-9B1EEEE46550=1|01443614-CD74-433A-B99E-2ECDC07BFC25=1|5BEB7EFE-FD9A-4556-801D-275E5FFC04CC=1|D3E037E1-3EB8-44C8-A917-57927947596D=1|3B576869-A4EC-4529-8536-B80A7769E899=1|75668C1F-73B5-4CF0-BB93-3ECF5CB7CC84=1|26190899-1602-49E8-8B27-EB1D0A1CE869=1|E6DB77E5-3DF2-4CF1-B95A-636979351E5B=1|D1E49AAC-8F56-4280-B9BA-993A6D77406C=1|B2B3F03D-6A65-4F7B-A9C7-1C7EF74A9BA4=1|92E97FA1-2EDF-4476-BDD6-9DD0B4DDDC7B=1|C1DB55AB-C21A-4637-BB3F-A12568109D35=1</Data>
      </Item>
    </Replace>

    <!-- Disable Exploit Protection Override by users -->
    <Replace>
      <CmdID>10</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/WindowsDefenderSecurityCenter/DisallowExploitProtectionOverride</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">int</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>1</Data>
      </Item>
    </Replace>

    <Final/>
  </SyncBody>
</SyncML>
