<dict>
	<key>PayloadContent</key>
	<array>
		<dict>
			<key>PayloadDisplayName</key>
			<string>Disable Apple Intelligence in Notes</string>
			<key>PayloadType</key>
			<string>com.apple.applicationaccess</string>
			<key>PayloadIdentifier</key>
			<string>com.fleetdm.cis-apple-intelligence-notes.check</string>
			<key>PayloadUUID</key>
			<string>D4E5F6A7-B8C9-0123-DEF0-234567890123</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>allowNotesTranscription</key>
			<false/>
