	<key>PayloadDescription</key>
	<string>Disables Apple Intelligence features in Notes (transcription, AI summarization) to prevent note content from being processed by AI. CIS macOS 15 benchmark.</string>
	<key>PayloadDisplayName</key>
	<string>[macOS 15] CIS - Ensure Apple Intelligence in Notes is disabled</string>
	<key>PayloadIdentifier</key>
	<string>com.fleetdm.macos15.cis-apple-intelligence-notes</string>
	<key>PayloadRemovalDisallowed</key>
	<false/>
