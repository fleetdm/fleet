<?xml version="1.0" encoding="utf-8"?>
<!--
  CIS Windows 10 Enterprise Benchmark v3.0.0 - User Rights Assignment Configuration Profile
  Applies user rights assignments via MDM/Intune SyncML

  Covered CIS Controls (Section 2.2):
  - 2.2.1  Access Credential Manager as a trusted caller -> No One (empty)
  - 2.2.2  Access this computer from the network        -> Administrators, Remote Desktop Users
  - 2.2.3  Act as part of the operating system         -> No One (empty)
  - 2.2.5  Allow log on locally                        -> Administrators, Users
  - 2.2.7  Back up files and directories               -> Administrators
  - 2.2.8  Change the system time                      -> Administrators, LOCAL SERVICE
  - 2.2.11 Create a token object                       -> No One (empty)
  - 2.2.12 Create global objects                       -> Administrators, LOCAL SERVICE, NETWORK SERVICE, SERVICE
  - 2.2.13 Create permanent shared objects             -> No One (empty)
  - 2.2.14 Create symbolic links                       -> Administrators
  - 2.2.15 Debug programs                              -> Administrators
  - 2.2.16 Deny access this computer from the network  -> Guests
  - 2.2.19 Deny log on locally                         -> Guests
  - 2.2.20 Deny log on through Remote Desktop Services -> Guests
  - 2.2.21 Enable computer and user accounts for delegation -> No One (empty)
  - 2.2.22 Force shutdown from a remote system         -> Administrators
  - 2.2.23 Generate security audits                    -> LOCAL SERVICE, NETWORK SERVICE
  - 2.2.24 Impersonate a client after authentication   -> Administrators, LOCAL SERVICE, NETWORK SERVICE, SERVICE
  - 2.2.25 Increase scheduling priority                -> Administrators
  - 2.2.26 Load and unload device drivers              -> Administrators
  - 2.2.27 Lock pages in memory                        -> No One (empty)
  - 2.2.30 Manage auditing and security log            -> Administrators
  - 2.2.31 Modify an object label                      -> No One (empty)
  - 2.2.32 Modify firmware environment values          -> Administrators
  - 2.2.34 Profile single process                      -> Administrators
  - 2.2.37 Restore files and directories               -> Administrators
  - 2.2.39 Take ownership of files or other objects    -> Administrators

  SID Reference:
  - S-1-5-6    = SERVICE
  - S-1-5-19   = LOCAL SERVICE
  - S-1-5-20   = NETWORK SERVICE
  - S-1-5-32-544 = Administrators
  - S-1-5-32-545 = Users
  - S-1-5-32-546 = Guests
  - S-1-5-32-555 = Remote Desktop Users
  Delimiter: &#xF000; (Unicode F000, null separator between SIDs/names)
-->
<SyncML xmlns="SYNCML:SYNCML1.2">
  <SyncBody>

    <!-- 2.2.1: Access Credential Manager as a trusted caller = No One -->
    <Replace>
      <CmdID>1</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/UserRights/AccessCredentialManagerAsTrustedCaller</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">chr</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data></Data>
      </Item>
    </Replace>

    <!-- 2.2.2: Access this computer from the network = Administrators, Remote Desktop Users -->
    <Replace>
      <CmdID>2</CmdID>
      <Item>
        <Target>
          <LocURI>./Device/Vendor/MSFT/Policy/Config/UserRights/AccessFromNetwork</LocURI>
        </Target>
        <Meta>
          <Format xmlns="syncml:metinf">chr</Format>
          <Type xmlns="syncml:metinf">text/plain</Type>
        </Meta>
        <Data>*S-1-5-32-544&#xF000;*S-1-5-32-555</Data>
      </Item>
    </Replace>

