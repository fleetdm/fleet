<!-- SOC 2 CC6 - Disable password hints on the Windows login screen -->
<Replace>
  <!-- Disable display of last logged-on user name -->
  <CmdID>1</CmdID>
  <Item>
    <Meta>
      <Format xmlns="syncml:metinf">int</Format>
    </Meta>
    <Target>
      <LocURI>./Device/Vendor/MSFT/Policy/Config/LocalPoliciesSecurityOptions/InteractiveLogon_DoNotDisplayLastSignedIn</LocURI>
    </Target>
    <!-- 1 = Enabled (do not display last user name) -->
    <Data>1</Data>
  </Item>
</Replace>

<Replace>
  <!-- Disable display of username at sign-in -->
  <CmdID>2</CmdID>
  <Item>
    <Meta>
      <Format xmlns="syncml:metinf">int</Format>
    </Meta>
    <Target>
      <LocURI>./Device/Vendor/MSFT/Policy/Config/LocalPoliciesSecurityOptions/InteractiveLogon_DoNotDisplayUsernameAtSignIn</LocURI>
    </Target>
    <!-- 1 = Enabled (do not display username) -->
    <Data>1</Data>
  </Item>
</Replace>
