<!-- Enable audit logging for account logon events -->
<Replace>
  <CmdID>1</CmdID>
  <Item>
    <Meta>
      <Format xmlns="syncml:metinf">int</Format>
    </Meta>
    <Target>
      <LocURI>./Device/Vendor/MSFT/Policy/Config/Audit/AccountLogon_AuditCredentialValidation</LocURI>
    </Target>
    <Data>3</Data>
  </Item>
</Replace>

