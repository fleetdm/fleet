<div id="partners" v-cloak>
  <div purpose="landing-page-container">
    <div purpose="landing-page-content">
      <div purpose="page-hero">
        <div purpose="hero-content">
          <div purpose="hero-heading">
            <h4>Partners</h4>
            <h1>Grow with Fleet</h1>
          </div>
          <div purpose="hero-text">
            <p>Whether you resell device management solutions or build technology that integrates with endpoint infrastructure, Fleet's partner program gives you the tools, support, and incentives to deliver more value to your customers.</p>
          </div>
          <div purpose="button-row">
            <a purpose="cta-button">
              Become a partner
            </a>
            <animated-arrow-button>Register a deal</animated-arrow-button>
          </div>
        </div>
        <div purpose="logos">
          <div purpose="logos-header">
            Trusted by leading channel partners
          </div>
          <div purpose="logo-carousel">
            <div purpose="logo-row" class="d-flex flex-row align-items-center" :class="[isIosThirteen ? 'ios-13-scroll-animation' : isSafariThirteen ? 'safari-13-scroll-animation' : '']">
              <img alt="Amaris logo" src="/images/logos/partner-logo-amaris-86x32.png">
              <img alt="Denali logo" src="/images/logos/partner-logo-denali-55x32@2x.png ">
              <img alt="SHI logo" src="/images/logos/partner-logo-shi-70x32@2x.png">
              <img alt="Myriad logo" src="/images/logos/partner-logo-myriad-360-146x32@2x.png">
              <img alt="3eye logo" src="/images/logos/partner-logo-3eye-74x32@2x.png">
              <img alt="CDW logo" src="/images/logos/partner-logo-cdw-60x32@2x.png">
              <img alt="Primo logo" src="/images/logos/partner-logo-primo-108x32@2x.png">
              <img alt="Wediggit logo" src="/images/logos/partner-logo-wediggit-94x32@2x.png">
              <img alt="Deel logo" src="/images/logos/partner-logo-deel-88x32@2x.png">
              <img alt="nDuo logo" src="/images/logos/partner-logo-nduo-100x32@2x.png">
              <img alt="Deeploi logo" src="/images/logos/partner-logo-deeploi-117x32@2x.png ">
              <img alt="Treeline logo" src="/images/logos/partner-logo-treeline-157x32@2x.png">
            </div>
            <div purpose="logo-row" class="d-flex flex-row align-items-center" :class="[isIosThirteen ? 'ios-13-scroll-animation' : isSafariThirteen ? 'safari-13-scroll-animation' : '']">
              <img alt="Amaris logo" src="/images/logos/partner-logo-amaris-86x32.png">
              <img alt="Denali logo" src="/images/logos/partner-logo-denali-55x32@2x.png ">
              <img alt="SHI logo" src="/images/logos/partner-logo-shi-70x32@2x.png">
              <img alt="Myriad logo" src="/images/logos/partner-logo-myriad-360-146x32@2x.png">
              <img alt="3eye logo" src="/images/logos/partner-logo-3eye-74x32@2x.png">
              <img alt="CDW logo" src="/images/logos/partner-logo-cdw-60x32@2x.png">
              <img alt="Primo logo" src="/images/logos/partner-logo-primo-108x32@2x.png">
              <img alt="Wediggit logo" src="/images/logos/partner-logo-wediggit-94x32@2x.png">
              <img alt="Deel logo" src="/images/logos/partner-logo-deel-88x32@2x.png">
              <img alt="nDuo logo" src="/images/logos/partner-logo-nduo-100x32@2x.png">
              <img alt="Deeploi logo" src="/images/logos/partner-logo-deeploi-117x32@2x.png ">
              <img alt="Treeline logo" src="/images/logos/partner-logo-treeline-157x32@2x.png">
            </div>
            <div purpose="fade-left"></div>
            <div purpose="fade-right"></div>
          </div>
        </div>
      </div><%// page-hero %>

      <div purpose="section">
        <div purpose="section-heading">
          <h2>Two ways to partner</h2>
          <p>Fleet works with resellers who bring our platform to new customers and technology partners who build integrations that extend Fleet's capabilities.</p>
        </div>

        <div purpose="details-cards">
          <div purpose="details-card">
            <div>
              <p purpose="card-heading">Reseller partners</p>
              <p purpose="card-subheading">VARs, MSPs, and IT service providers</p>
            </div>
            <p>Sell Fleet to your customers with dedicated support from our team. You handle the relationship; we provide the platform, training, and technical enablement to help you close deals and deliver successful deployments.</p>
            <div purpose="checklist">
              <p>Deal registration and pipeline protection</p>
              <p>Competitive margins and volume incentives</p>
              <p>Sales engineering and pre-sales support</p>
              <p>Co-branded marketing materials</p>
              <p>Technical training and certification</p>
              <p>Dedicated partner manager</p>
            </div>
            <div>
              <a purpose="cta-button" @click="clickOpenPartnerModal('reseller')">Apply to resell Fleet</a>
            </div>
          </div>
          <div purpose="details-card">
            <div>
              <p purpose="card-heading">Technology partners</p>
              <p purpose="card-subheading">ISVs, security vendors, and platform providers</p>
            </div>
            <p>Build integrations that connect your product with Fleet. Fleet's open API, webhook events, and osquery foundation make it straightforward to deliver joint value to shared customers.</p>
            <div purpose="checklist">
              <p>REST API and webhook integration support</p>
              <p>Joint solution briefs and documentation</p>
              <p>Co-marketing and co-selling opportunities</p>
              <p>Access to Fleet's engineering team</p>
              <p>Listing on Fleet's integrations page</p>
              <p>Early access to new APIs and features</p>
            </div>
            <div>
              <a purpose="cta-button" @click="clickOpenPartnerModal('integrations')">Become a technology partner</a>
            </div>
          </div>
        </div>
      </div>

      <div purpose="section">
        <div purpose="section-heading">
          <h2>Why choose Fleet</h2>
        </div>
        <div purpose="features-section">
          <div purpose="feature">
            <h5>Open-source foundation</h5>
            <p>Fleet is built on <a href="/handbook/company#history">osquery</a> and <a href="/handbook/company/why-this-way#why-open-source">open-source</a> principles. Your customers can audit the code, verify what data is collected, and avoid vendor lock-in.</p>
          </div>
          <div purpose="feature">
            <h5>Cross-platform by default</h5>
            <p>macOS, Windows, Linux, iOS, Android, ChromeOS, and cloud infrastructure — all from one platform. One deal covers the entire fleet.</p>
          </div>
          <div purpose="feature">
            <h5>Cloud or self-hosted</h5>
            <p>Let Fleet host it, or deploy on-prem, in any cloud, or air-gapped. 100% feature parity either way. Flexibility that opens doors other MDM vendors can't.</p>
          </div>
          <div purpose="feature">
            <h5>GitOps-native</h5>
            <p>The only device management platform built for infrastructure-as-code. Peer-reviewed config changes, instant rollback, full audit trail.</p>
          </div>
          <div purpose="feature">
            <h5>API-first architecture</h5>
            <p>Every feature accessible via REST API. Technology partners can build deep integrations without workarounds.</p>
          </div>
          <div purpose="feature">
            <h5>Growing market opportunity</h5>
            <p>Organizations are moving away from legacy MDM vendors. Fleet's open approach is attracting enterprises like Stripe, Fastly, and Gusto.</p>
          </div>
        </div>
      </div>


    </div>
  </div>
  <div purpose="banner-container">
    <div purpose="bottom-cta">
      <div>
        <h2>Ready to partner with Fleet?</h2>
        <p>Talk to our team about how Fleet can help you deliver more value to your customers.</p>
      </div>
      <div purpose="button-row">
        <a purpose="cta-button">
          Become a partner
        </a>
        <animated-arrow-button>Register a deal</animated-arrow-button>
      </div>

    </div>

  </div>
  <%/* Cloud city banner */%>
  <parallax-city></parallax-city>
  <modal v-if="modal === 'partner'" @close="closeModal()">
    <div purpose="modal-form">
      <div purpose="form-heading">
      <h2>Become a partner</h2>
      <p>Tell us about your business and how you’d like to partner with Fleet.</p>
    </div>
      <ajax-form action="deliverPartnerRegistrationSubmission" :syncing.sync="syncing" :cloud-error.sync="cloudError" :form-errors.sync="formErrors" :form-data="partnerFormData" :form-rules="partnerFormRules" @submitted="submittedPartnerForm()">
        <div purpose="form-section">
          <div class="row">
            <div class="col-12 col-sm-6 pr-sm-2">
              <div class="form-group">
                <label for="partner-first-name">First name *</label>
                <input class="form-control" id="partner-first-name" type="text"  :class="[formErrors.firstName ? 'is-invalid' : '']" v-model.trim="partnerFormData.firstName" autocomplete="first-name" >
                <div class="invalid-feedback" v-if="formErrors.firstName">Please enter your first name.</div>
              </div>
            </div>
            <div class="col-12 col-sm-6 pl-sm-2">
              <div class="form-group">
                <label for="parner-last-name">Last name *</label>
                <input class="form-control" id="parner-last-name" type="text"  :class="[formErrors.lastName ? 'is-invalid' : '']" v-model.trim="partnerFormData.lastName" autocomplete="last-name" >
                <div class="invalid-feedback" v-if="formErrors.lastName">Please enter your last name.</div>
              </div>
            </div>
          </div>
          <div class="form-group">
            <label for="partner-email-address">Email *</label>
            <input class="form-control" id="partner-email-address"  :class="[formErrors.submittersEmailAddress ? 'is-invalid' : '']" v-model.trim="partnerFormData.submittersEmailAddress" >
            <div class="invalid-feedback" v-if="formErrors.submittersEmailAddress" focus-first>This doesn’t appear to be a valid email address</div>
          </div>
          <div class="form-group">
            <label for="partner-organization">Company *</label>
            <input class="form-control" id="partner-organization" type="text"  :class="[formErrors.submittersOrganization ? 'is-invalid' : '']" v-model.trim="partnerFormData.submittersOrganization" >
            <div class="invalid-feedback" v-if="formErrors.submittersOrganization">Please enter the name of your organization.</div>
          </div>
          <div class="form-group">
            <strong>How will you work with Fleet?</strong>
            <label purpose="form-option" class="form-control" :class="[partnerFormData.partnerType === 'login' ? 'reseller' : '']">
              <input type="radio" v-model.trim="partnerFormData.partnerType" value="reseller" >
              <span purpose="custom-radio"><span purpose="custom-radio-selected"></span></span>
              Resell or manage devices for customers
            </label>
            <label purpose="form-option" class="form-control" :class="[partnerFormData.partnerType === 'integrations' ? 'selected' : '']">
              <input type="radio" v-model.trim="partnerFormData.partnerType" value="integrations">
              <span purpose="custom-radio"><span purpose="custom-radio-selected"></span></span>
              Build integrations with Fleet
            </label>
          </div>
        </div>
        <div purpose="form-section">
          <div class="form-group">
            <label for="partner-website">Website</label>
            <input class="form-control" id="partner-website" v-model.trim="partnerFormData.partnerWebsite" >
          </div>
          <div class="form-group">
            <label for="partner-country">Country</label>
            <input class="form-control" id="partner-country" v-model.trim="partnerFormData.partnerCountry" >
          </div>
          <div v-if="partnerFormData.partnerType === 'reseller'">
            <label purpose="checkbox-group-label" for="partner-services-offered">Services offered</label>
            <div class="form-group" :class="[formErrors.servicesOffered ? 'is-invalid' : '']">
              <div purpose="input-group">
                <label purpose="custom-checkbox-label" for="mdm" @click="clickSelectCustomCheckbox()">
                  <span purpose="custom-checkbox" :class="[partnerFormData.servicesOffered.mdm ? 'checked' : '']" ><span purpose="custom-checkbox-check"></span></span>
                  <input type="checkbox" v-model.trim="partnerFormData['servicesOffered'].mdm" id="mdm">
                  MDM / endpoint management
                </label>
                <label purpose="custom-checkbox-label" for="security-services" @click="clickSelectCustomCheckbox()">
                  <span purpose="custom-checkbox" :class="[partnerFormData.servicesOffered.securityServices ? 'checked' : '']" ><span purpose="custom-checkbox-check"></span></span>
                  <input type="checkbox" v-model.trim="partnerFormData['servicesOffered'].securityServices" id="security-services">
                  Security services (MSSP)
                </label>
                <label purpose="custom-checkbox-label" for="it-services" @click="clickSelectCustomCheckbox()">
                  <span purpose="custom-checkbox" :class="[partnerFormData.servicesOffered.itServices ? 'checked' : '']" ><span purpose="custom-checkbox-check"></span></span>
                  <input type="checkbox" v-model.trim="partnerFormData['servicesOffered'].itServices" id="it-services">
                  IT services / MSP
                </label>
                <label purpose="custom-checkbox-label" for="consulting" @click="clickSelectCustomCheckbox()">
                  <span purpose="custom-checkbox" :class="[partnerFormData.servicesOffered.consulting ? 'checked' : '']" ><span purpose="custom-checkbox-check"></span></span>
                  <input type="checkbox" v-model.trim="partnerFormData['servicesOffered'].consulting" id="consulting">
                  Consulting
                </label>
              </div>
            </div>
            <div class="form-group">
              <label for="partner-number-of-hosts">Approx. endpoints managed</label>
              <select class="form-control custom-select" v-model.trim="partnerFormData.numberOfHosts" :class="[formErrors.numberOfHosts ? 'is-invalid' : '']">
                <option :value="undefined">Select</option>
                <option value="1 - 100">1 - 100</option>
                <option value="100 - 1000">100 - 1,000</option>
                <option value="1000 - 5000">1,000 - 5,000</option>
                <option value="5000+">5,000+</option>
              </select>
              <div class="invalid-feedback">Please select an option.</div>
            </div>

          </div>
          <div v-else>
            <div class="form-group">
              <label for="partner-service-description">Which best describes your services?</label>
              <select class="form-control custom-select" id="partner-service-description" v-model.trim="partnerFormData.servicesDescription" :class="[formErrors.servicesDescription ? 'is-invalid' : '']">
                <option :value="undefined">Select</option>
                <option value="Security">Security</option>
                <option value="Identity">Identity</option>
                <option value="Infrastructure / cloud">Infrastructure / cloud</option>
                <option value="Developer tools">Developer tools</option>
                <option value="IT operations">IT operations</option>
                <option value="Other">Other</option>
              </select>
              <div class="invalid-feedback">Please select an option.</div>
            </div>

          </div>
          <div class="form-group">
            <div v-if="partnerFormData.partnerType === 'reseller'">
            <label for="notes">Tell us about your services or customers</label>
            <p>E.g., types of customers, deployments, or services you offer.</p>
            </div>
            <div v-else>
              <label for="notes">Tell us about your integration</label>
              <p>E.g., data integration, product integration, or co-marketing.</p>
            </div>
            <textarea class="form-control" id="notes" type="textarea" v-model.trim="partnerFormData.notes" >
            </textarea>
          </div>
        </div>
        <cloud-error purpose="cloud-error" v-if="cloudError"></cloud-error>
        <ajax-button purpose="submit-button" spinner="true" type="submit" :syncing="syncing" class="btn btn-block btn-lg btn-primary mt-4" v-if="!cloudError">Submit</ajax-button>
        <ajax-button purpose="submit-button" type="button" :syncing="syncing" class="btn btn-block btn-lg btn-primary mt-4" v-if="cloudError" @click="clickResetForm()">Try again</ajax-button>
      </ajax-form>
    </div>
  </modal>
</div>
<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser() %>
