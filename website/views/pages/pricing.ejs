    </div>
    <div purpose="features-table" class="d-flex flex-column justify-content-center mx-auto px-0" :class="[[pricingMode === 'Security' ? 'show' : 'hide']]">
      <div class="d-flex flex-column p-0" :class="[showExpandedTable ? '' : 'truncated']">
