        "url": "/case-study/foursquare",
        "title": "Foursquare",
        "lastModifiedAt": 1778824528020,
        "htmlId": "articles--foursquare--03e969cb3f",
        "sectionRelativeRepoPath": "foursquare.md",
        "meta": {
          "category": "case study",
          "companyLogoFilename": "foursquare-logo-212x40@2x.png",
          "articleTitle": "Foursquare cut costs and gained 114% ROI with Fleet",
          "description": "Foursquare replaced two MDM tools with Fleet, cut maintenance work by 50%, reduced costs by 24%, and achieved 114% ROI.",
          "publishedOn": "2025-12-11",
          "authorGitHubUsername": "n/a",
          "authorFullName": "Fleetdm",
          "quoteContent": "“One of the easiest, quickest, smoothest migrations I’ve ever done.”",
          "quoteAuthorImageFilename": "mike-meyer-120x120@2x.png",
          "quoteAuthorName": "Mike Meyer",
          "quoteAuthorJobTitle": "Senior systems engineer & Technical lead",
          "companyName": "Foursquare",
          "companyInfo": "Foursquare is the industry's leading geospatial technology platform, designed to help businesses make smarter decisions and create more engaging customer experiences.",
          "companyInfoLineTwo": "Powered by deep machine learning and a privacy-forward approach, their technology and solutions are redefining how organizations derive value from location intelligence.",
          "summaryChallenge": "Foursquare wanted to simplify how they managed Macs and Windows devices. Their devices were split across two different MDMs, which created extra work and made automation harder for a small IT team.",
          "summarySolution": "Fleet provided Foursquare with a single MDM platform that supports both Mac and Windows. Migrating from their previous MDMs was seamless and easy, thanks to Fleet-provided out-of-the-box tools that added speed and simplicity.",
          "summaryKeyResults": "Cut endpoint maintenance effort by 50%; Reduced licensing costs by 24%; Achieved 114% ROI by removing duplicate tools; Real-time visibility with direct integration to their SIEM, with no latency; Increased reliability of security controls with GitOps"
        }
      },
      {
        "url": "/articles/free-migration-from-jamf-to-fleet",
        "title": "Free migration from jamf to Fleet",
        "lastModifiedAt": 1778824528021,
        "htmlId": "articles--free-migration-from---3cb837ee45",
