ce 'com.northpolesec.santa.bundleservice' && remove_launchctl_service 'com.northpolesec.santa.metricservice' && remove_launchctl_service 'com.northpolesec.santa.syncservice' && remove_launchctl_service 'com.northpolesec.santad' && remove_pkg_files 'com.northpolesec.santa' && forget_pkg 'com.northpolesec.santa' && sudo rm -rf '/Applications/Santa.app' && sudo rm -rf '/usr/local/bin/santactl' && sudo rm -rf '/var/db/santa' && sudo rm -rf '/var/log/santa*' && trash $LOGGED_IN_USER '/private/etc/asl/com.northpolesec.santa.asl.conf' && trash $LOGGED_IN_USER '/private/etc/newsyslog.d/com.northpolesec.santa.newsyslog.conf'",
