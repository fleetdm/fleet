            "description": "The HTTP response body",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          }
        ],
        "fleetRepoUrl": "https://github.com/fleetdm/fleet/blob/main/schema/tables/curl.yml"
      },
