      {
        "name": "kernel_keys",
        "description": "List of security data, authentication keys and encryption keys.",
        "url": "https://fleetdm.com/tables/kernel_keys",
        "platforms": [
          "linux"
        ],
        "evented": false,
        "cacheable": false,
        "notes": "",
