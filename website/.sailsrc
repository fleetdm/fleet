          },
          {
            "name": "query",
            "description": "The exact query to run",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "interval",
            "description": "The interval in seconds to run this query, not an exact interval",
            "type": "integer",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "executions",
            "description": "Number of times the query was executed",
            "type": "bigint",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "last_executed",
            "description": "UNIX time stamp in seconds of the last completed execution",
            "type": "bigint",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
