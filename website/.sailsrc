kgutil --only-dirs --files \"$PKGID\" | sed \"s|^|${FULL_INSTALL_LOCATION}/|\" | grep '\\.app$' | tr '\\n' '\\0' | /usr/bin/sudo -u root -E -- /usr/bin/xargs -0 -- /bin/rm -rf; root_app_dir=$(; sudo pkgutil --only-dirs --files \"$PKGID\" \\; | sed \"s|^|${FULL_INSTALL_LOCATION}/|\" \\; | grep 'Applications' \\; | awk '{ print length, $0 }' \\; | sort -n \\; | head -n1 \\; | cut -d' ' -f2-; ); if [ -n \"$root_app_dir\" ]; then echo \"sudo rmdir -p \\\"$root_app_dir\\\" 2>/dev/null || :\"; sudo rmdir -p \"$root_app_dir\" 2>/dev/null || :; fi } && trash() { local logged_in_user=\"$1\"; local target_file=\"$2\"; local timestamp=\"$(date +%Y-%m-%d-%s)\"; local rand=\"$(jot -r 1 0 99999)\"; if [[ \"$target_file\" == ~* ]]; then target_file=\"/Users/$logged_in_user${target_file:1}\"; fi; local trash=\"/Users/$logged_in_user/.Trash\"; local file_name=\"$(basename \"${target_file}\")\"; if [[ -e \"$target_file\" ]]; then echo \"removing $target_file.\"; mv -f \"$target_file\" \"$trash/${file_name}_${timestamp}_${rand}\"; else echo \"$target_file doesn't exist.\"; fi } && remove_pkg_files 'com.amazon.redshiftodbc' && forget_pkg 'com.amazon.redshiftodbc' && remove_pkg_files 'com.simba.sparkodbc' && forget_pkg 'com.simba.sparkodbc' && remove_pkg_files 'com.simba.sqlserverodbc' && forget_pkg 'com.simba.sqlserverodbc' && remove_pkg_files 'com.tableausoftware.Desktop.app' && forget_pkg 'com.tableausoftware.Desktop.app' && remove_pkg_files 'com.tableausoftware.DesktopShortcut' && forget_pkg 'com.tableausoftware.DesktopShortcut' && remove_pkg_files 'com.tableausoftware.extensions' && forget_pkg 'com.tableausoftware.extensions' && remove_pkg_files 'com.tableausoftware.FLEXNet.*' && forget_pkg 'com.tableausoftware.FLEXNet.*' && remove_pkg_files 'com.tableausoftware.mysql' && forget_pkg 'com.tableausoftware.mysql' && remove_pkg_files 'com.tableausoftware.networkExtensions' && forget_pkg 'com.tableausoftware.networkExtensions' && remove_pkg_files 'com.tableausoftware.oracle' && forget_p