        "platforms": [
          "windows"
        ],
        "evented": false,
        "cacheable": false,
        "notes": "",
        "examples": "```\nselect ipv4_internet from connectivity\n```",
        "columns": [
          {
            "name": "disconnected",
            "description": "True if the all interfaces are not connected to any network",
