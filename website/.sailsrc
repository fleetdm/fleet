          },
          {
            "name": "flags",
            "description": "A set of flags describing the state of the key.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "usage",
            "description": "the number of threads and open file references that refer to this key.",
