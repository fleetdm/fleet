      {
        "name": "MITRE - Custom Directory Monitoring",
        "platform": "linux, darwin",
        "description": "Template: Monitor files in a custom directory. Replace /YOUR_DIRECTORY/ with the path to monitor - ATT&CK T1158,T1100",
        "query": "SELECT hash.sha1, fi.path, fi.filename, datetime(fi.btime, 'unixepoch', 'UTC')\nas btime, datetime(fi.atime, 'unixepoch', 'UTC') as atime, datetime(fi.ctime,\n'unixepoch', 'UTC') as ctime, datetime(fi.mtime, 'unixepoch', 'UTC') as mtime\nFROM hash JOIN file fi USING (path) where ((fi.path like '/YOUR_DIRECTORY/%/%') OR\n(fi.path like '/YOUR_DIRECTORY/%%/.%') OR (fi.path like '/YOUR_DIRECTORY/.%') OR (fi.path\nlike '/YOUR_DIRECTORY/%'));",
