            "type": "bigint",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "type",
            "description": "The key type.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "description",
            "description": "The key description.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          }
