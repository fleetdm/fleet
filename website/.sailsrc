      {
        "name": "recent_files",
        "description": "Recently files (as displayed in Start Menu or File Explorer).",
        "url": "https://fleetdm.com/tables/recent_files",
        "platforms": [
          "windows"
        ],
        "evented": false,
        "cacheable": false,
        "notes": "",
        "examples": "```\nSELECT recent_files.* FROM users CROSS JOIN recent_files USING (uid) WHERE mtime > unixepoch('now') - 3600\n```",
        "columns": [
          {
            "name": "uid",
            "description": "The local user ID",
            "type": "bigint",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": true
          },
          {
            "name": "filename",
            "description": "The name of the file",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "path",
            "description": "The full path of the file",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "type",
            "description": "Display type for the file",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
