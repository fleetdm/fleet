          },
          {
            "name": "model",
            "description": "The model of the CPU.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "manufacturer",
            "description": "The manufacturer of the CPU.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "processor_type",
            "description": "The processor type, such as Central, Math, or Video.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "cpu_status",
            "description": "The current operating status of the CPU.",
            "type": "integer",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "number_of_cores",
            "description": "The number of cores of the CPU.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "logical_processors",
            "description": "The number of logical processors of the CPU.",
            "type": "integer",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "address_width",
            "description": "The width of the CPU address bus.",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
