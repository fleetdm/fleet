            "type": "integer",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false,
            "platforms": [
              "Linux",
              "Windows"
            ]
          }
        ],
        "fleetRepoUrl": "https://github.com/fleetdm/fleet/blob/main/schema/tables/secureboot.yml"
      },
