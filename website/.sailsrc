      {
        "name": "Software last opened at ",
        "platform": "windows",
        "description": "A software override query to append last_opened_at information to Windows software entries.",
        "query": "SELECT\n  MAX(last_run_time) AS last_opened_at,\n  REGEX_MATCH(accessed_files, \"VOLUME[^\\\\]+([^,]+\" || REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(filename, '\\', '\\\\'), '.', '\\.'), '*', '\\*'), '+', '\\+'), '?', '\\?'), '[', '\\['), ']', '\\]'), '{', '\\{'), '}', '\\}'), '(', '\\('), ')', '\\)'), '|', '\\|') || \")\", 1) AS executable_path\nFROM prefetch\nGROUP BY executable_path\n",
        "purpose": "Informational",
        "tags": [
          "built-in"
        ],
        "kind": "built-in",
        "slug": "software-last-opened-at-windows",
        "lineNumberInYaml": 1664
      },
      {
        "name": "Software last opened at ",
        "platform": "linux",
        "description": "A software override query to append last_opened_at information to Linux DEB software entries. The accuracy of this information is limited by the accuracy of the atime column in the file table, which can be affected by the system clock and mount settings like noatime and relatime.",
        "query": "SELECT\n    package,\n    MAX(atime) AS last_opened_at\nFROM deb_package_files\nCROSS JOIN file USING (path)\nWHERE type = 'regular'\n  AND regex_match(file.mode, '[1357]', 0)\nGROUP BY package;\n",
        "discovery": "deb_package_files",
        "purpose": "Informational",
        "tags": [
          "built-in"
        ],
        "kind": "built-in",
        "slug": "software-last-opened-at-linux",
        "lineNumberInYaml": 1679
      },
