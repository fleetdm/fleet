        "query": "select DISTINCT p.name, p.path, pos.remote_address, pos.remote_port from\nprocess_open_sockets pos LEFT JOIN processes p ON pos.pid = p.pid WHERE pos.remote_port\n!= 0 AND p.name != '';",
