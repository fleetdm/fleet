t' && sudo rm -rf '/Library/LaunchDaemons/com.philandro.anydesk.Helper.plist' && sudo rm -rf '/Library/LaunchDaemons/com.philandro.anydesk.service.plist' && sudo rm -rf '/Library/PrivilegedHelperTools/com.philandro.anydesk.Helper' && sudo rm -rf \"$APPDIR/AnyDesk.app\" && trash $LOGGED_IN_USER '~/.anydesk' && trash $LOGGED_IN_USER '~/Library/Preferences/com.philandro.anydesk.plist'",
