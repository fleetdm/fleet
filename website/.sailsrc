      {
        "name": "MITRE - AppData Local Directory Creation",
        "platform": "windows",
        "description": "Check suspicious directory creation under AppData\\Local - ATT&CK T1034,T1074,T1044",
        "query": "select f.path,f.directory,u.username,f.hard_links,f.symlink,datetime(f.btime,\n'unixepoch', 'UTC') as btime, datetime(f.atime, 'unixepoch', 'UTC') as atime,\ndatetime(f.ctime, 'unixepoch', 'UTC') as ctime, datetime(f.mtime, 'unixepoch',\n'UTC') as mtime from file f LEFT JOIN users u on f.uid=u.uid where f.path like\n'C:\\users\\%\\AppData\\Local\\%' AND f.type='directory';",
        "purpose": "Detection",
        "tags": [
          "mitre",
          "att&ck",
          "threat detection"
        ],
        "contributors": [
