        "notes": "",
        "examples": "Connect over HTTP and retrieve statistics about the process. This is useful to\ndetect machines on slow networks, or that have no Internet access.\n\n```\nSELECT round_trip_time FROM curl WHERE URL='https://fleetdm.com';\n```",
        "columns": [
          {
            "name": "url",
