&& trash $LOGGED_IN_USER '~/Library/Caches/com.axosoft.gitkraken.ShipIt' && trash $LOGGED_IN_USER '~/Library/Caches/GitKraken' && trash $LOGGED_IN_USER '~/Library/Cookies/com.axosoft.gitkraken.binarycookies' && trash $LOGGED_IN_USER '~/Library/HTTPStorages/com.axosoft.gitkraken' && trash $LOGGED_IN_USER '~/Library/Preferences/com.axosoft.gitkraken.helper.plist' && trash $LOGGED_IN_USER '~/Library/Preferences/com.axosoft.gitkraken.plist' && trash $LOGGED_IN_USER '~/Library/Saved Application State/com.axosoft.gitkraken.savedState'",
