/, \"\"); print}'); if [ -z \"$INSTALL_LOCATION\" ] || [ \"$INSTALL_LOCATION\" = \"/\" ]; then FULL_INSTALL_LOCATION=\"$VOLUME\"; else FULL_INSTALL_LOCATION=\"$VOLUME/$INSTALL_LOCATION\"; FULL_INSTALL_LOCATION=$(echo \"$FULL_INSTALL_LOCATION\" | sed 's|//|/|g'); fi; echo \"sudo pkgutil --only-files --files \\\"$PKGID\\\" | sed \\\"s|^|${FULL_INSTALL_LOCATION}/|\\\" | tr '\\\\\\\\n' '\\\\\\\\0' | /usr/bin/sudo -u root -E -- /usr/bin/xargs -0 -- /bin/rm -rf\"; sudo pkgutil --only-files --files \"$PKGID\" | sed \"s|^|/${INSTALL_LOCATION}/|\" | tr '\\n' '\\0' | /usr/bin/sudo -u root -E -- /usr/bin/xargs -0 -- /bin/rm -rf; echo \"sudo pkgutil --only-dirs --files \\\"$PKGID\\\" | sed \\\"s|^|${FULL_INSTALL_LOCATION}/|\\\" | grep '\\\\.app$' | tr '\\\\\\\\n' '\\\\\\\\0' | /usr/bin/sudo -u root -E -- /usr/bin/xargs -0 -- /bin/rm -rf\"; sudo pkgutil --only-dirs --files \"$PKGID\" | sed \"s|^|${FULL_INSTALL_LOCATION}/|\" | grep '\\.app$' | tr '\\n' '\\0' | /usr/bin/sudo -u root -E -- /usr/bin/xargs -0 -- /bin/rm -rf; root_app_dir=$(; sudo pkgutil --only-dirs --files \"$PKGID\" \\; | sed \"s|^|${FULL_INSTALL_LOCATION}/|\" \\; | grep 'Applications' \\; | awk '{ print length, $0 }' \\; | sort -n \\; | head -n1 \\; | cut -d' ' -f2-; ); if [ -n \"$root_app_dir\" ]; then echo \"sudo rmdir -p \\\"$root_app_dir\\\" 2>/dev/null || :\"; sudo rmdir -p \"$root_app_dir\" 2>/dev/null || :; fi } && trash() { local logged_in_user=\"$1\"; local target_file=\"$2\"; local timestamp=\"$(date +%Y-%m-%d-%s)\"; local rand=\"$(jot -r 1 0 99999)\"; if [[ \"$target_file\" == ~* ]]; then target_file=\"/Users/$logged_in_user${target_file:1}\"; fi; local trash=\"/Users/$logged_in_user/.Trash\"; local file_name=\"$(basename \"${target_file}\")\"; if [[ -e \"$target_file\" ]]; then echo \"removing $target_file.\"; mv -f \"$target_file\" \"$trash/${file_name}_${timestamp}_${rand}\"; else echo \"$target_file doesn't exist.\"; fi } && remove_launchctl_service 'Adobe_Genuine_Software_Integrity_Service' && remove_launchctl_service 'com.adobe.AAM.Startup-1.0' && remove_launchctl_service 'com.adobe.AAM.Updater-1.0' && remove_launchctl_service 'com.adobe.agsservice' && remove_launchctl_service 'com.adobe.ARMDC.Communicator' && remove_launchctl_service 'com.adobe.ARMDC.SMJobBlessHelper' && remove_launchctl_service 'com.adobe.ARMDCHelper.cc24aef4a1b90ed56a725c38014c95072f92651fb65e1bf9c8e43c37a23d420d' && remove_pkg_files 'com.adobe.acrobat.DC.*' && forget_pkg 'com.adobe.acrobat.DC.*' && remove_pkg_files 'com.adobe.AcroServicesUpdater' && forget_pkg 'com.adobe.AcroServicesUpdater' && remove_pkg_files 'com.adobe.armdc.app.pkg' && forget_pkg 'com.adobe.armdc.app.pkg' && remove_pkg_files 'com.adobe.PDApp.AdobeApplicationManager.installer.pkg' && forget_pkg 'com.adobe.PDApp.AdobeApplicationManager.installer.pkg' && sudo rm -rf '/Applications/Adobe Acrobat DC/' && trash $LOGGED_IN_USER '~/Library/Application Support/Adobe/Acrobat' && trash $LOGGED_IN_USER '~/Library/Caches/Acrobat' && trash $LOGGED_IN_USER '~/Library/Caches/com.adobe.Acrobat.Pro' && trash $LOGGED_IN_USER '~/Library/HTTPStorages/com.adobe.Acrobat.Pro' && trash $LOGGED_IN_USER '~/Library/HTTPStorages/com.adobe.Acrobat.Pro.binarycookies' && trash $LOGGED_IN_USER '~/Library/Preferences/Adobe/Acrobat' && trash $LOGGED_IN_USER '~/Library/Preferences/com.adobe.Acrobat.Pro.plist' && trash $LOGGED_IN_USER '~/Library/Saved Application State/com.adobe.Acrobat.Pro.savedState' && trash $LOGGED_IN_USER '~/Library/WebKit/com.adobe.Acrobat.Pro'",
