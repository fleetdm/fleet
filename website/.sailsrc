d}\"; else echo \"$target_file doesn't exist.\"; fi } && quit_application 'com.adobe.adobedigitaleditions.app' && remove_pkg_files 'com.adobe.adobedigitaleditions.app' && forget_pkg 'com.adobe.adobedigitaleditions.app' && sudo rm -rf '/Applications/Adobe Digital Editions.app' && trash $LOGGED_IN_USER '~/Library/Application Support/com.apple.sharedfilelist/com.apple.LSSharedFileList.ApplicationRecentDocuments/com.adobe.adobedigitaleditions.app.sfl*' && trash $LOGGED_IN_USER '~/Library/HTTPStorages/com.adobe.adobedigitaleditions.app' && trash $LOGGED_IN_USER '~/Library/Preferences/com.adobe.adobedigitaleditions.app.plist'",
