 root_app_dir=$(; sudo pkgutil --only-dirs --files \"$PKGID\" \\; | sed \"s|^|${FULL_INSTALL_LOCATION}/|\" \\; | grep 'Applications' \\; | awk '{ print length, $0 }' \\; | sort -n \\; | head -n1 \\; | cut -d' ' -f2-; ); if [ -n \"$root_app_dir\" ]; then echo \"sudo rmdir -p \\\"$root_app_dir\\\" 2>/dev/null || :\"; sudo rmdir -p \"$root_app_dir\" 2>/dev/null || :; fi } && trash() { local logged_in_user=\"$1\"; local target_file=\"$2\"; local timestamp=\"$(date +%Y-%m-%d-%s)\"; local rand=\"$(jot -r 1 0 99999)\"; if [[ \"$target_file\" == ~* ]]; then target_file=\"/Users/$logged_in_user${target_file:1}\"; fi; local trash=\"/Users/$logged_in_user/.Trash\"; local file_name=\"$(basename \"${target_file}\")\"; if [[ -e \"$target_file\" ]]; then echo \"removing $target_file.\"; mv -f \"$target_file\" \"$trash/${file_name}_${timestamp}_${rand}\"; else echo \"$target_file doesn't exist.\"; fi } && remove_launchctl_service 'org.openvpn.client' && remove_launchctl_service 'org.openvpn.helper' && quit_application 'org.openvpn.client.app' && remove_pkg_files 'org.openvpn.client.pkg' && forget_pkg 'org.openvpn.client.pkg' && remove_pkg_files 'org.openvpn.client_framework.pkg' && forget_pkg 'org.openvpn.client_framework.pkg' && remove_pkg_files 'org.openvpn.client_launch.pkg' && forget_pkg 'org.openvpn.client_launch.pkg' && remove_pkg_files 'org.openvpn.client_uninstall.pkg' && forget_pkg 'org.openvpn.client_uninstall.pkg' && remove_pkg_files 'org.openvpn.helper_framework.pkg' && forget_pkg 'org.openvpn.helper_framework.pkg' && remove_pkg_files 'org.openvpn.helper_launch.pkg' && forget_pkg 'org.openvpn.helper_launch.pkg' && sudo rm -rf '/Applications/OpenVPN Connect' && sudo rm -rf '/Applications/OpenVPN Connect.app' && (cd /Users/$LOGGED_IN_USER && 'security' 'delete-keychain' 'openvpn.keychain-db') || true && trash $LOGGED_IN_USER '~/Library/Application Support/OpenVPN Connect' && trash $LOGGED_IN_USER '~/Library/Logs/OpenVPN Connect' && trash $LOGGED_IN_USER '~/Library/Prefere