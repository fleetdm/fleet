        "uninstallScript": "APPDIR=\"/Applications/\" && LOGGED_IN_USER=$(scutil <<< \"show State:/Users/ConsoleUser\" | awk '/Name :/ { print $3 }') && trash() { local logged_in_user=\"$1\"; local target_file=\"$2\"; local timestamp=\"$(date +%Y-%m-%d-%s)\"; local rand=\"$(jot -r 1 0 99999)\"; if [[ \"$target_file\" == ~* ]]; then target_file=\"/Users/$logged_in_user${target_file:1}\"; fi; local trash=\"/Users/$logged_in_user/.Trash\"; local file_name=\"$(basename \"${target_file}\")\"; if [[ -e \"$target_file\" ]]; then echo \"removing $target_file.\"; mv -f \"$target_file\" \"$trash/${file_name}_${timestamp}_${rand}\"; else echo \"$target_file doesn't exist.\"; fi } && sudo rm -rf \"$APPDIR/Nova.app\" && sudo rm -rf '/Library/LaunchDaemons/com.panic.NovaPrivilegedHelper.plist' && sudo rm -rf '/Library/PrivilegedHelperTools/com.panic.NovaPrivilegedHelper' && trash $LOGGED_IN_USER '~/Library/Application Scripts/com.panic.Nova.NovaQuickLookPreview' && trash $LOGGED_IN_USER '~/Library/Application Scripts/com.panic.Nova.NovaQuickLookThumbnail' && trash $LOGGED_IN_USER '~/Library/Application Support/com.apple.sharedfilelist/com.apple.LSSharedFileList.ApplicationRecentDocuments/com.panic.nova.sfl*' && trash $LOGGED_IN_USER '~/Library/Caches/com.panic.Nova' && trash $LOGGED_IN_USER '~/Library/Containers/com.panic.Nova.NovaQuickLookPreview' && trash $LOGGED_IN_USER '~/Library/Containers/com.panic.Nova.NovaQuickLookThumbnail' && trash $LOGGED_IN_USER '~/Library/Preferences/com.panic.Nova.plist' && trash $LOGGED_IN_USER '~/Library/WebKit/com.panic.Nova'",
