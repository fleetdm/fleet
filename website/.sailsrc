            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "category",
            "description": "System extension category",
            "type": "text",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "bundle_path",
