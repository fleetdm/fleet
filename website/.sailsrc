      {
        "name": "process_open_files",
        "description": "File descriptors for each process.",
        "url": "https://fleetdm.com/tables/process_open_files",
        "platforms": [
          "darwin",
          "linux"
        ],
        "evented": false,
        "cacheable": false,
        "notes": "",
        "examples": "See what processes have which files open, for example, what processes are\ncurrently interacting with files with 1Password in their name?\n\n```\nSELECT f.path file_path, p.path process_path FROM process_open_files f JOIN processes p ON p.pid = f.pid WHERE f.path LIKE '%1Password%';\n```",
        "columns": [
          {
            "name": "pid",
