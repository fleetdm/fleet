in_user=\"$1\"; local target_file=\"$2\"; local timestamp=\"$(date +%Y-%m-%d-%s)\"; local rand=\"$(jot -r 1 0 99999)\"; if [[ \"$target_file\" == ~* ]]; then target_file=\"/Users/$logged_in_user${target_file:1}\"; fi; local trash=\"/Users/$logged_in_user/.Trash\"; local file_name=\"$(basename \"${target_file}\")\"; if [[ -e \"$target_file\" ]]; then echo \"removing $target_file.\"; mv -f \"$target_file\" \"$trash/${file_name}_${timestamp}_${rand}\"; else echo \"$target_file doesn't exist.\"; fi } && remove_launchctl_service 'net.tunnelblick.tunnelblick.LaunchAtLogin' && remove_launchctl_service 'net.tunnelblick.tunnelblick.tunnelblickd' && quit_application 'net.tunnelblick.tunnelblick' && sudo rm -rf '/Library/Application Support/Tunnelblick' && sudo rm -rf \"$APPDIR/Tunnelblick.app\" && trash $LOGGED_IN_USER '~/Library/Application Support/Tunnelblick' && trash $LOGGED_IN_USER '~/Library/Caches/com.apple.helpd/SDMHelpData/Other/English/HelpSDMIndexFile/Tunnelblick*' && trash $LOGGED_IN_USER '~/Library/Caches/net.tunnelblick.tunnelblick' && trash $LOGGED_IN_USER '~/Library/Cookies/net.tunnelblick.tunnelblick.binarycookies' && trash $LOGGED_IN_USER '~/Library/HTTPStorages/net.tunnelblick.tunnelblick' && trash $LOGGED_IN_USER '~/Library/Preferences/net.tunnelblick.tunnelblick.plist'",
