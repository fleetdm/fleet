            "type": "bigint",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "file_backed",
            "description": "Total number of file backed pages.",
            "type": "bigint",
            "notes": "",
            "hidden": false,
            "required": false,
            "index": false
          },
          {
            "name": "anonymous",
