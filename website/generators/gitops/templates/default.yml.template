    #
    #   ‚ÄĘ No trailing slash at the end
    #   ‚ÄĘ `http://` or `https://` at the beginning.
    #
    # (You can copy this from the URL bar in your browser.)
    ###########################################################
    server_url: https://fleet.example.com # TODO: Replace with the URL where Fleet is running.

