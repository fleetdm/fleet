# Fleet MCP Server — Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────

# Port for the SSE transport (not used in stdio mode)
PORT=8181

# Bearer token that MCP clients must send in the Authorization header.
# Required in production. Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=YOUR_MCP_AUTH_TOKEN

# ── Fleet ─────────────────────────────────────────────────────────────────────

# Base URL of your Fleet instance (include scheme and port if non-standard)
FLEET_BASE_URL=https://your-fleet.example.com

# Fleet API token — generate one in Fleet under Settings > Integrations > API
# Docs: https://fleetdm.com/docs/using-fleet/rest-api#authentication
FLEET_API_KEY=YOUR_FLEET_API_KEY

# ── Logging ───────────────────────────────────────────────────────────────────

# Verbosity: debug | info | warn | error
LOG_LEVEL=info

# ── TLS (choose one option if your Fleet uses a self-signed cert) ─────────────

# Option A: Skip TLS verification — DEV/TEST ONLY, never use in production
# FLEET_TLS_SKIP_VERIFY=true

# Option B: Provide your CA certificate (recommended for self-signed certs)
# FLEET_CA_FILE=/path/to/ca.pem
