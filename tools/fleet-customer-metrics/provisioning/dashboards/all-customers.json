      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_per_env AS (\n  SELECT *,\n    ROW_NUMBER() OVER (PARTITION BY \"anonymousIdentifier\" ORDER BY \"updatedTime\" DESC) AS rn\n  FROM usage_data\n)\nSELECT\n  c.organization AS \"Organization\",\n  SUM(l.\"numHostsEnrolled\")::int AS \"Hosts enrolled\",\n  SUM(l.\"numUsers\")::int AS \"Users\",\n  MAX(l.\"licenseTier\") AS \"Tier\",\n  string_agg(DISTINCT l.\"fleetVersion\", ', ' ORDER BY l.\"fleetVersion\" DESC) AS \"Fleet version\",\n  SUM(l.\"numSoftwareTitles\")::int AS \"Software titles\",\n  SUM(l.\"numSoftwareCVEs\")::int AS \"CVEs\",\n  EXTRACT(EPOCH FROM MAX(l.\"updatedTime\")) * 1000 AS \"Last updated\"\nFROM latest_per_env l\nJOIN customers c ON l.\"anonymousIdentifier\" = c.\"anonymousIdentifier\"\nWHERE l.rn = 1\nGROUP BY c.organization\nORDER BY \"Hosts enrolled\" DESC;",
          "refId": "A",
          "sql": {
