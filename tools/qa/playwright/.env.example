FLEET_URL=https://your-fleet-server.example.com
FLEET_API_TOKEN=
FLEET_ADMIN_EMAIL=
FLEET_ADMIN_PASSWORD=
FLEET_OBSERVER_EMAIL=
FLEET_OBSERVER_PASSWORD=

# Optional — enable SSO login tests (requires Fleet's SimpleSAML docker container).
# When set to 1, the SSO tests in login-flow.spec.ts will run. They always target
# https://localhost:8080 because SimpleSAML's entity_id binds the SAML ACS there.
FLEET_SSO_ENABLED=

# Optional — override the NATS server URL for log destination tests.
# If unset, the test auto-detects from Fleet's logging config (when the NATS
# plugin is configured). Useful when the test machine reaches NATS on a
# different host/port than Fleet does.
FLEET_NATS_URL=

# Optional — directory where Fleet writes filesystem log files.
# When set, the Filesystem log delivery tests in log-destination-flow.spec.ts
# will run and assert log files exist and were written recently.
FLEET_LOG_FILES_PATH=
